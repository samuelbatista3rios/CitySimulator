# Genesis City — variáveis do servidor (copie para .env e ajuste)

# Porta HTTP/WebSocket (Fly usa 8080; local pode ser 4000)
PORT=4000

# População inicial e seed da cidade
GENESIS_SEED=1337
GENESIS_POP=10000

# Intervalo de autosave (minutos)
AUTOSAVE_MIN=5

# PostgreSQL (opcional — sem ele a cidade roda em memória, sem persistir)
# Em provedores gerenciados (Neon/Supabase) use a connection string deles:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=genesis_city
